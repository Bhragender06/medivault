FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Database (Docker Compose uses postgres service name `db`)
DATABASE_URL=postgresql+psycopg2://medivault:medivault@db:5432/medivault

# CORS
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# JWT
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# Uploads
MAX_CONTENT_LENGTH_MB=15
ALLOWED_UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png,docx

# Excel export
REGISTRATION_XLSX_PATH=backend/exports/registration.xlsx

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://127.0.0.1:8080/oauth/callback

# OTP (Twilio optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# PostgreSQL
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/medivault

# Optional
JWT_ACCESS_TOKEN_EXPIRES=86400
CORS_ORIGINS=*
